{
    "name": "rastik1584/laravel-mapycz-api",
    "description": "A Laravel package for integrating with Mapy.cz API",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "rastik1584",
            "email": "author@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Rastik1584\\LaravelMapyczApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rastik1584\\LaravelMapyczApi\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rastik1584\\LaravelMapyczApi\\MapyczApiServiceProvider"
            ],
            "aliases": {
                "MapyczApi": "Rastik1584\\LaravelMapyczApi\\Facades\\MapyczApi"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}